{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "control-center-layer": "top",
  "control-center-width": 420,
  "control-center-height": 800,
  "fit-to-screen": true,
  "widgets": [
    "title",
    "dnd",
    "buttons-grid",
    "mpris",
    "notifications"
  ],
  "widget-config": {
    "title": {
      "text": "󰕮 Control Center",
      "clear-all-button": true,
      "button-text": "󰎟 Clear"
    },
    "dnd": {
      "text": "  Do Not Disturb"
    },
    "buttons-grid": {
      "actions": [
        {
          "label": "",
          "command": "swaync-client -t && rofi -show drun -show-icons -display-drun ' Apps '"
        },
        {
          "label": "",
          "command": "swaync-client -t && ~/Scripts/Rofi/wallpaper.sh standalone"
        },
        {
          "label": "󰅇",
          "command": "swaync-client -t && ~/Scripts/Rofi/cliphist.sh standalone"
        },
        {
          "label": "󰍹",
          "command": "swaync-client -t && ~/Scripts/monitor-switch.sh toggle"
        }
      ]
    },
    "mpris": {
      "blacklist": [
        "^(?!org\\.mpris\\.MediaPlayer2\\.spotify$).*"
      ],
      "autohide": true,
      "show-album-art": "always",
      "loop-carousel": true
    },
    "notifications": {
      "vexpand": true
    }
  }
}
